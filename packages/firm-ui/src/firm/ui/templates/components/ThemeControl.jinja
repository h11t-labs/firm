{#def current, choices, request_path #}
{# `current` ({label, icon}) and `choices` ({value, label, icon, active}) are precomputed in
   render.py; each choice posts to /settings/theme and redirects back. No client JS — the server
   stores the choice in a cookie and sets data-theme on <html>, which the CSS reads. #}
<details class="dropdown"><summary>{{ icons[current.icon] }}{{ current.label }}{{ icons.chevron }}</summary><div class="dropdown-menu">{% for opt in choices %}<form class="inline" method="post" action="/settings/theme"><input type="hidden" name="theme" value="{{ opt.value }}"><input type="hidden" name="return" value="{{ request_path }}"><button class="dropdown-opt{{ " active" if opt.active else "" }}" type="submit">{{ opt.label }}{% if opt.active %}{{ icons.check }}{% endif %}</button></form>{% endfor %}</div></details>
