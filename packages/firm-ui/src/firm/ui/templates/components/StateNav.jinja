{#def items #}
{# `items` is a list of {state, url, count, active}; render.py builds the URLs and counts. #}
<nav class="sub">{% for item in items %}<a class="{{ "active" if item.active else "" }}" href="{{ item.url }}"><Dot state={{ item.state }} />{{ item.state }}{% if item.count is not none %}<span class="n">{{ item.count }}</span>{% endif %}</a>{% endfor %}</nav>
